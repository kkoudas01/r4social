# ΧΡΗΣΗ ΣΥΝΑΡΤΗΣΗΣ:
# Δημιουργία χάρτη για τη στήλη "ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ"
choropleth_map <- create_choropleth(
fill_column = ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ,
legend_title = "Ψηφιακές Υπηρεσίες Δήμου"
)
# ΕΜΦΑΝΙΣΗ ΤΟΥ ΧΑΡΤΗ
choropleth_map
# ΧΡΗΣΗ ΣΥΝΑΡΤΗΣΗΣ:
# Δημιουργία χάρτη για τη στήλη "ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ"
choropleth_map <- create_choropleth(
fill_column = ΟΔΙΚΟ_ΔΙΚΤΥΟ,
legend_title = "Οδικό Δίκτυο Δήμου"
)
# ΕΜΦΑΝΙΣΗ ΤΟΥ ΧΑΡΤΗ
choropleth_map
# ΟΙ ΠΑΡΑΚΑΤΩ ΜΕΤΑΒΛΗΤΕΣ ΕΛΕΓΧΟΥΝ ΤΗΝ ΟΠΤΙΚΗ ΕΜΦΑΝΙΣΗ ΤΟΥ ΧΑΡΤΗ
# ΜΠΟΡΕΙΣ ΝΑ ΤΙΣ ΑΛΛΑΖΕΙΣ ΕΛΕΥΘΕΡΑ ΓΙΑ ΝΑ ΠΡΟΣΑΡΜΟΖΕΙΣ ΤΟΝ ΧΑΡΤΗ
# Επιλογή χρωματικής παλέτας από το viridis package
# Διαθέσιμες επιλογές: "magma", "viridis", "plasma", "cividis", "inferno", "mako"
my_palette_choice <- "magma"
# my_palette_choice <- "viridis"
# my_palette_choice <- "plasma"
# my_palette_choice <- "cividis"
# Χρώμα των γραμμών που διαχωρίζουν τους δήμους
MAIN_COLOR <- "gray80"
# Πάχος των γραμμών συνόρων (σε μονάδες γραφικών)
LINE_WIDTH <- 0.05
# Χρώμα για τους δήμους που δεν έχουν δεδομένα (NA values)
NA_COLOR <- "#7393B3"
# Κατεύθυνση της χρωματικής κλίμακας:
#  1 = από ανοιχτό (χαμηλές τιμές) προς σκούρο (υψηλές τιμές)
# -1 = από σκούρο (χαμηλές τιμές) προς ανοιχτό (υψηλές τιμές)
DIRECTION <- -1
# ΣΥΝΑΡΤΗΣΗ ΔΗΜΙΟΥΡΓΙΑΣ CHOROPLETH ΧΑΡΤΗ
# Παράμετροι:
#   data: sf object με γεωμετρίες δήμων και δεδομένα
#   fill_column: η στήλη που περιέχει τις αριθμητικές τιμές για χρωματισμό
#   title: ο κύριος τίτλος του χάρτη
#   legend_title: ο τίτλος της λεζάντας που εξηγεί την κλίμακα χρωμάτων
create_choropleth <- function(data = sf_final,
fill_column,
title = "Βαθμολογία Υπηρεσιών Δήμων (2025)",
legend_title) {
# ΔΗΜΙΟΥΡΓΙΑ ΒΑΣΙΚΟΥ GGPLOT ΑΝΤΙΚΕΙΜΕΝΟΥ
ggplot(data = data) +
# ΣΧΕΔΙΑΣΜΟΣ ΤΩΝ ΠΟΛΥΓΩΝΩΝ ΤΩΝ ΔΗΜΩΝ
# aes(fill = {{fill_column}}): κάθε δήμος γεμίζει με χρώμα ανάλογα της τιμής στη στήλη fill_column
# color: χρώμα των περιγραμμάτων μεταξύ δήμων
# linewidth: πάχος των γραμμών των συνόρων
geom_sf(aes(fill = {{fill_column}}),
color = MAIN_COLOR,
linewidth = LINE_WIDTH) +
# ΡΥΘΜΙΣΗ ΧΡΩΜΑΤΙΚΗΣ ΚΛΙΜΑΚΑΣ
# option: επιλογή παλέτας (από τη μεταβλητή my_palette_choice)
# name: τίτλος της λεζάντας (legend)
# na.value: χρώμα για δήμους χωρίς δεδομένα
# direction: κατεύθυνση χρωματικής κλίμακας (από σκούρο προς ανοιχτό ή αντίστροφα)
scale_fill_viridis_c(
option = my_palette_choice,
name = legend_title,
na.value = NA_COLOR,
direction = DIRECTION
) +
# ΘΕΜΑ ΧΑΡΤΗ - ΑΠΟΜΑΚΡΥΝΣΗ ΟΛΩΝ ΤΩΝ ΑΞΟΝΩΝ ΚΑΙ ΣΗΜΕΙΩΝ
theme_void() +
# ΤΙΤΛΟΙ ΚΑΙ ΕΠΙΓΡΑΦΕΣ
labs(
title = title,
caption = "Δεδομένα: Υπουργείο Εσωτερικών - Ελληνική Στατιστική Αρχή"
) +
# ΠΡΟΣΑΡΜΟΓΗ ΘΕΜΑΤΟΣ
theme(
# Κεντραρισμένος τίτλος με έντονη γραφή και μεγάλο μέγεθος
plot.title = element_text(hjust = 0.5, size = 16, face = "bold"),
# Κεντραρισμένος υπότιτλος (αν χρησιμοποιηθεί)
plot.subtitle = element_text(hjust = 0.5, size = 12),
# Τοποθέτηση λεζάντας στη δεξιά πλευρά
legend.position = "right",
# Κεντραρισμένη επιγραφή πηγής δεδομένων, μικρότερη και σε γκρι
plot.caption = element_text(hjust = 0.5, size = 8, color = "gray50")
)
}
# ΧΡΗΣΗ ΣΥΝΑΡΤΗΣΗΣ:
# Δημιουργία χάρτη για τη στήλη "ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ"
choropleth_map <- create_choropleth(
fill_column = ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ,
legend_title = "Ψηφιακές Υπηρεσίες Δήμου"
)
# ΕΜΦΑΝΙΣΗ ΤΟΥ ΧΑΡΤΗ
choropleth_map
# ΟΙ ΠΑΡΑΚΑΤΩ ΜΕΤΑΒΛΗΤΕΣ ΕΛΕΓΧΟΥΝ ΤΗΝ ΟΠΤΙΚΗ ΕΜΦΑΝΙΣΗ ΤΟΥ ΧΑΡΤΗ
# ΜΠΟΡΕΙΣ ΝΑ ΤΙΣ ΑΛΛΑΖΕΙΣ ΕΛΕΥΘΕΡΑ ΓΙΑ ΝΑ ΠΡΟΣΑΡΜΟΖΕΙΣ ΤΟΝ ΧΑΡΤΗ
# Επιλογή χρωματικής παλέτας από το viridis package
# Διαθέσιμες επιλογές: "magma", "viridis", "plasma", "cividis", "inferno", "mako"
my_palette_choice <- "magma"
# my_palette_choice <- "viridis"
# my_palette_choice <- "plasma"
# my_palette_choice <- "cividis"
# Χρώμα των γραμμών που διαχωρίζουν τους δήμους
MAIN_COLOR <- "gray80"
# Πάχος των γραμμών συνόρων (σε μονάδες γραφικών)
LINE_WIDTH <- 0.05
# Χρώμα για τους δήμους που δεν έχουν δεδομένα (NA values)
NA_COLOR <- "#e9eef3"
# Κατεύθυνση της χρωματικής κλίμακας:
#  1 = από ανοιχτό (χαμηλές τιμές) προς σκούρο (υψηλές τιμές)
# -1 = από σκούρο (χαμηλές τιμές) προς ανοιχτό (υψηλές τιμές)
DIRECTION <- -1
# ΣΥΝΑΡΤΗΣΗ ΔΗΜΙΟΥΡΓΙΑΣ CHOROPLETH ΧΑΡΤΗ
# Παράμετροι:
#   data: sf object με γεωμετρίες δήμων και δεδομένα
#   fill_column: η στήλη που περιέχει τις αριθμητικές τιμές για χρωματισμό
#   title: ο κύριος τίτλος του χάρτη
#   legend_title: ο τίτλος της λεζάντας που εξηγεί την κλίμακα χρωμάτων
create_choropleth <- function(data = sf_final,
fill_column,
title = "Βαθμολογία Υπηρεσιών Δήμων (2025)",
legend_title) {
# ΔΗΜΙΟΥΡΓΙΑ ΒΑΣΙΚΟΥ GGPLOT ΑΝΤΙΚΕΙΜΕΝΟΥ
ggplot(data = data) +
# ΣΧΕΔΙΑΣΜΟΣ ΤΩΝ ΠΟΛΥΓΩΝΩΝ ΤΩΝ ΔΗΜΩΝ
# aes(fill = {{fill_column}}): κάθε δήμος γεμίζει με χρώμα ανάλογα της τιμής στη στήλη fill_column
# color: χρώμα των περιγραμμάτων μεταξύ δήμων
# linewidth: πάχος των γραμμών των συνόρων
geom_sf(aes(fill = {{fill_column}}),
color = MAIN_COLOR,
linewidth = LINE_WIDTH) +
# ΡΥΘΜΙΣΗ ΧΡΩΜΑΤΙΚΗΣ ΚΛΙΜΑΚΑΣ
# option: επιλογή παλέτας (από τη μεταβλητή my_palette_choice)
# name: τίτλος της λεζάντας (legend)
# na.value: χρώμα για δήμους χωρίς δεδομένα
# direction: κατεύθυνση χρωματικής κλίμακας (από σκούρο προς ανοιχτό ή αντίστροφα)
scale_fill_viridis_c(
option = my_palette_choice,
name = legend_title,
na.value = NA_COLOR,
direction = DIRECTION
) +
# ΘΕΜΑ ΧΑΡΤΗ - ΑΠΟΜΑΚΡΥΝΣΗ ΟΛΩΝ ΤΩΝ ΑΞΟΝΩΝ ΚΑΙ ΣΗΜΕΙΩΝ
theme_void() +
# ΤΙΤΛΟΙ ΚΑΙ ΕΠΙΓΡΑΦΕΣ
labs(
title = title,
caption = "Δεδομένα: Υπουργείο Εσωτερικών - Ελληνική Στατιστική Αρχή"
) +
# ΠΡΟΣΑΡΜΟΓΗ ΘΕΜΑΤΟΣ
theme(
# Κεντραρισμένος τίτλος με έντονη γραφή και μεγάλο μέγεθος
plot.title = element_text(hjust = 0.5, size = 16, face = "bold"),
# Κεντραρισμένος υπότιτλος (αν χρησιμοποιηθεί)
plot.subtitle = element_text(hjust = 0.5, size = 12),
# Τοποθέτηση λεζάντας στη δεξιά πλευρά
legend.position = "right",
# Κεντραρισμένη επιγραφή πηγής δεδομένων, μικρότερη και σε γκρι
plot.caption = element_text(hjust = 0.5, size = 8, color = "gray50")
)
}
# Υπολογισμός του midpoint (π.χ. ο Μέσος Όρος)
# ΣΗΜΑΝΤΙΚΟ: Βάζουμε na.rm = TRUE για να αγνοήσουμε τα NA κατά τον υπολογισμό.
my_midpoint <- median(sf_final$ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ, na.rm = TRUE)
my_low_color <- "blue"
my_high_color <- "black"
# Βήμα 3.2: Δημιουργία Χρωροπληθούς Χάρτη
choropleth_map <- ggplot(data = sf_final) +
geom_sf(aes(fill = ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ),
color = "gray70",
linewidth = 0.001) +
scale_fill_gradient2(
low = my_low_color,    # Χαμηλά: Μπλε
mid = "red",        # Κέντρο: Κίτρινο
high = my_high_color,  # Υψηλά: Κόκκινο
# === Η ΛΥΣΗ ΕΙΝΑΙ ΕΔΩ! ===
midpoint = my_midpoint,
# ==========================
name = "Ψηφιακές Υπηρεσίες Δήμου",
na.value = "white"
) +
theme_void() +
labs(
title = "Βαθμολογία Υπηρεσιών Δήμων (2025)",
caption = "Δεδομένα: Υπουργείο Εσωτερικών - Ελληνική Στατιστική Αρχή"
) +
theme(
plot.title = element_text(hjust = 0.5, size = 16, face = "bold"),
plot.subtitle = element_text(hjust = 0.5, size = 12),
legend.position = "right"
)
# Προβολή του χάρτη
print(choropleth_map)
# Υπολογισμός του midpoint (π.χ. ο Μέσος Όρος)
# ΣΗΜΑΝΤΙΚΟ: Βάζουμε na.rm = TRUE για να αγνοήσουμε τα NA κατά τον υπολογισμό.
my_midpoint <- median(sf_final$ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ, na.rm = TRUE)
my_low_color <- "blue"
my_high_color <- "black"
# Βήμα 3.2: Δημιουργία Χρωροπληθούς Χάρτη
choropleth_map <- ggplot(data = sf_final) +
geom_sf(aes(fill = ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ),
color = "gray70",
linewidth = 0.001) +
scale_fill_gradient2(
low = my_low_color,    # Χαμηλά: Μπλε
mid = "red",        # Κέντρο: Κίτρινο
high = my_high_color,  # Υψηλά: Κόκκινο
# === Η ΛΥΣΗ ΕΙΝΑΙ ΕΔΩ! ===
midpoint = my_midpoint,
# ==========================
name = "Ψηφιακές Υπηρεσίες Δήμου",
na.value = "#7393B3"
) +
theme_void() +
labs(
title = "Βαθμολογία Υπηρεσιών Δήμων (2025)",
caption = "Δεδομένα: Υπουργείο Εσωτερικών - Ελληνική Στατιστική Αρχή"
) +
theme(
plot.title = element_text(hjust = 0.5, size = 16, face = "bold"),
plot.subtitle = element_text(hjust = 0.5, size = 12),
legend.position = "right"
)
# Προβολή του χάρτη
print(choropleth_map)
# Υπολογισμός του midpoint (π.χ. ο Μέσος Όρος)
# ΣΗΜΑΝΤΙΚΟ: Βάζουμε na.rm = TRUE για να αγνοήσουμε τα NA κατά τον υπολογισμό.
my_midpoint <- median(sf_final$ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ, na.rm = TRUE)
my_low_color <- "blue"
my_high_color <- "black"
# Βήμα 3.2: Δημιουργία Χρωροπληθούς Χάρτη
choropleth_map <- ggplot(data = sf_final) +
geom_sf(aes(fill = ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ),
color = "gray70",
linewidth = 0.001) +
scale_fill_gradient2(
low = my_low_color,    # Χαμηλά: Μπλε
mid = "red",        # Κέντρο: Κίτρινο
high = my_high_color,  # Υψηλά: Κόκκινο
# === Η ΛΥΣΗ ΕΙΝΑΙ ΕΔΩ! ===
midpoint = my_midpoint,
# ==========================
name = "Ψηφιακές Υπηρεσίες Δήμου",
na.value = "white"
) +
theme_void() +
labs(
title = "Βαθμολογία Υπηρεσιών Δήμων (2025)",
caption = "Δεδομένα: Υπουργείο Εσωτερικών - Ελληνική Στατιστική Αρχή"
) +
theme(
plot.title = element_text(hjust = 0.5, size = 16, face = "bold"),
plot.subtitle = element_text(hjust = 0.5, size = 12),
legend.position = "right"
)
# Προβολή του χάρτη
print(choropleth_map)
# Υπολογισμός του midpoint (π.χ. ο Μέσος Όρος)
# ΣΗΜΑΝΤΙΚΟ: Βάζουμε na.rm = TRUE για να αγνοήσουμε τα NA κατά τον υπολογισμό.
my_low_color <- "blue"
my_high_color <- "black"
# Βήμα 3.2: Δημιουργία Χρωροπληθούς Χάρτη
choropleth_map <- ggplot(data = sf_final) +
geom_sf(aes(fill = ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ),
color = "gray70",
linewidth = 0.001) +
scale_fill_gradient(colours = rainbow(5),
name = "Ψηφιακές Υπηρεσίες Δήμου",
na.value = "white"
) +
theme_void() +
labs(
title = "Βαθμολογία Υπηρεσιών Δήμων (2025)",
caption = "Δεδομένα: Υπουργείο Εσωτερικών - Ελληνική Στατιστική Αρχή"
) +
theme(
plot.title = element_text(hjust = 0.5, size = 16, face = "bold"),
plot.subtitle = element_text(hjust = 0.5, size = 12),
legend.position = "right"
)
# Υπολογισμός του midpoint (π.χ. ο Μέσος Όρος)
# ΣΗΜΑΝΤΙΚΟ: Βάζουμε na.rm = TRUE για να αγνοήσουμε τα NA κατά τον υπολογισμό.
my_low_color <- "blue"
my_high_color <- "black"
# Βήμα 3.2: Δημιουργία Χρωροπληθούς Χάρτη
choropleth_map <- ggplot(data = sf_final) +
geom_sf(aes(fill = ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ),
color = "gray70",
linewidth = 0.001) +
scale_fill_gradient(colours = rainbow(5),
name = "Ψηφιακές Υπηρεσίες Δήμου",
na.value = "white"
) +
theme_void() +
labs(
title = "Βαθμολογία Υπηρεσιών Δήμων (2025)",
caption = "Δεδομένα: Υπουργείο Εσωτερικών - Ελληνική Στατιστική Αρχή"
) +
theme(
plot.title = element_text(hjust = 0.5, size = 16, face = "bold"),
plot.subtitle = element_text(hjust = 0.5, size = 12),
legend.position = "right"
)
# 1. Υπολογισμός των 5 σημείων ελέγχου (Quantiles)
# Αυτά είναι τα σημεία στα οποία θέλεις να αντιστοιχίσεις συγκεκριμένα χρώματα.
quantiles <- quantile(sf_final$ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ,
probs = c(0, 0.25, 0.50, 0.75, 1),
na.rm = TRUE)
# 2. Ορισμός των 5 χρωμάτων
# Επέλεξε 5 διαφορετικά χρώματα για τα 5 σημεία ελέγχου.
my_5_colors <- c("red", "orange", "yellow", "lightgreen", "darkgreen")
# 3. Ορισμός των θέσεων (values)
# Καθώς το scale_fill_gradientn λειτουργεί με τιμές από 0 έως 1,
# πρέπει να μετατρέψουμε τις τιμές των ποσοστημορίων σε κλίμακα 0-1
# (δηλαδή, να τις κανονικοποιήσουμε).
min_val <- min(sf_final$ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ, na.rm = TRUE)
max_val <- max(sf_final$ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ, na.rm = TRUE)
# Υπολογισμός κανονικοποιημένων θέσεων (τιμές από 0 έως 1)
# Η φόρμουλα είναι: (τιμή - min) / (max - min)
normalized_values <- (quantiles - min_val) / (max_val - min_val)
# Βήμα 3.2: Δημιουργία Χρωροπληθούς Χάρτη
choropleth_map <- ggplot(data = sf_final) +
geom_sf(aes(fill = ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ),
color = "gray70",
linewidth = 0.001) +
# === Η ΤΕΛΙΚΗ ΛΥΣΗ ΕΙΝΑΙ ΕΔΩ! ===
scale_fill_gradientn(
colors = my_5_colors, # Τα 5 χρώματα που ορίσαμε
values = normalized_values, # Οι 5 κανονικοποιημένες θέσεις (0 έως 1)
name = "Ψηφιακές Υπηρεσίες Δήμου",
na.value = "white"
) +
# =================================
theme_void() +
labs(
title = "Βαθμολογία Υπηρεσιών Δήμων (2025)",
caption = "Δεδομένα: Υπουργείο Εσωτερικών - Ελληνική Στατιστική Αρχή"
) +
theme(
plot.title = element_text(hjust = 0.5, size = 16, face = "bold"),
plot.subtitle = element_text(hjust = 0.5, size = 12),
legend.position = "right"
)
# Προβολή του χάρτη
print(choropleth_map)
create_choropleth <- function(data = sf_final,
fill_column,
title = "Βαθμολογία Υπηρεσιών Δήμων (2025)",
legend_title) {
# Υπολογισμός των 5 ποσοστημορίων
quantiles <- quantile(data %>% pull({{fill_column}}),
probs = c(0, 0.25, 0.50, 0.75, 1),
na.rm = TRUE)
# Ορισμός των 5 χρωμάτων
my_5_colors <- c("red", "orange", "yellow", "lightgreen", "darkgreen")
# Υπολογισμός κανονικοποιημένων τιμών (0-1)
min_val <- min(data %>% pull({{fill_column}}), na.rm = TRUE)
max_val <- max(data %>% pull({{fill_column}}), na.rm = TRUE)
normalized_values <- (quantiles - min_val) / (max_val - min_val)
# Δημιουργία ggplot αντικειμένου
ggplot(data = data) +
geom_sf(aes(fill = {{fill_column}}),
color = MAIN_COLOR,
linewidth = LINE_WIDTH) +
# Χρήση scale_fill_gradientn με τα προσαρμοσμένα χρώματα και τιμές
scale_fill_gradientn(
colors = my_5_colors,
values = normalized_values,
name = legend_title,
na.value = NA_COLOR
) +
theme_void() +
labs(
title = title,
caption = "Δεδομένα: Υπουργείο Εσωτερικών - Ελληνική Στατιστική Αρχή"
) +
theme(
plot.title = element_text(hjust = 0.5, size = 16, face = "bold"),
plot.subtitle = element_text(hjust = 0.5, size = 12),
legend.position = "right",
plot.caption = element_text(hjust = 0.5, size = 8, color = "gray50")
)
}
# ΧΡΗΣΗ ΣΥΝΑΡΤΗΣΗΣ:
# Δημιουργία χάρτη για τη στήλη "ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ"
choropleth_map <- create_choropleth(
fill_column = ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ,
legend_title = "Ψηφιακές Υπηρεσίες Δήμου"
)
# ΕΜΦΑΝΙΣΗ ΤΟΥ ΧΑΡΤΗ
choropleth_map
# ΧΡΗΣΗ ΣΥΝΑΡΤΗΣΗΣ:
# Δημιουργία χάρτη για τη στήλη "ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ"
choropleth_map <- create_choropleth(
fill_column = ΟΔΙΚΟ_ΔΙΚΤΥΟ,
legend_title = "Οδικό Δίκτυο Δήμου"
)
# ΕΜΦΑΝΙΣΗ ΤΟΥ ΧΑΡΤΗ
choropleth_map
