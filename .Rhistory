color = MAIN_COLOR,
linewidth = LINE_WIDTH) +
# Χρήση scale_fill_gradientn με τα προσαρμοσμένα χρώματα και τιμές
scale_fill_gradientn(
colors = my_5_colors,
values = normalized_values,
name = legend_title,
na.value = NA_COLOR
) +
theme_void() +
labs(
title = title,
caption = "Δεδομένα: Υπουργείο Εσωτερικών - Ελληνική Στατιστική Αρχή"
) +
theme(
plot.title = element_text(hjust = 0.5, size = 16, face = "bold"),
plot.subtitle = element_text(hjust = 0.5, size = 12),
legend.position = "right",
plot.caption = element_text(hjust = 0.5, size = 8, color = "gray50")
)
}
# ΧΡΗΣΗ ΣΥΝΑΡΤΗΣΗΣ:
# Δημιουργία χάρτη για τη στήλη "ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ"
choropleth_map <- create_choropleth(
fill_column = ΨΗΦΙΑΚΕΣ_ΥΠΗΡΕΣΙΕΣ,
legend_title = "Ψηφιακές Υπηρεσίες Δήμου"
)
# ΕΜΦΑΝΙΣΗ ΤΟΥ ΧΑΡΤΗ
choropleth_map
