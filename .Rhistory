library(kableExtra)
rm(list = ls())
# Φόρτωση βιβλιοθηκών
if(!require(readr)){
install.packages("readr")
library(readr)
}
# 1. Εισαγωγή των Datasets με σύντομα ονόματα
res_count <- read_csv("researchers-in-rd-per-million-people.csv")
gdp       <- read_csv("gdp-per-capita-worldbank.csv")
gini      <- read_csv("economic-inequality-gini-index.csv")
edu_total <- read_csv("total-government-expenditure-on-education-gdp.csv")
rd_spend  <- read_csv("research-spending-gdp.csv")
edu_total  <- read_csv("government-spending-on-education-by-level-as-a-share-of-gdp.csv")
pop_edu   <- read_csv("population-having-attained-at-least-basic-education.csv")
if(!require(dplyr)){
install.packages("dplyr")
library(dplyr)
}
if(!require(purrr)){
install.packages("purrr")
library(purrr)
}
# 1. Προετοιμασία των dataframes (ίδια όπως πριν)
df1 <- res_count %>% select(Entity, Code, Year, researchers = 4)
df2 <- gdp       %>% select(Entity, Code, Year, gdp_per_capita = 4)
df3 <- gini      %>% select(Entity, Code, Year, gini_index = 4)
df4 <- edu_total %>% select(Entity, Code, Year, gov_edu_total = 4)
df5 <- rd_spend  %>% select(Entity, Code, Year, rd_share_gdp = 4)
df7 <- pop_edu   %>% select(Entity, Code, Year, pop_basic_edu = 4)
df6_all <- edu_tert %>% rename(exp_tert=4, exp_u_sec=5, exp_l_sec=6, exp_primary=7, exp_pre_pri=8)
View(edu_total)
# Φόρτωση βιβλιοθηκών
if(!require(readr)){
install.packages("readr")
library(readr)
}
# 1. Εισαγωγή των Datasets με σύντομα ονόματα
res_count <- read_csv("researchers-in-rd-per-million-people.csv")
gdp       <- read_csv("gdp-per-capita-worldbank.csv")
gini      <- read_csv("economic-inequality-gini-index.csv")
edu_total <- read_csv("total-government-expenditure-on-education-gdp.csv")
rd_spend  <- read_csv("research-spending-gdp.csv")
edu_tert  <- read_csv("government-spending-on-education-by-level-as-a-share-of-gdp.csv")
pop_edu   <- read_csv("population-having-attained-at-least-basic-education.csv")
View(edu_tert)
if(!require(dplyr)){
install.packages("dplyr")
library(dplyr)
}
if(!require(purrr)){
install.packages("purrr")
library(purrr)
}
# 1. Προετοιμασία των dataframes (ίδια όπως πριν)
df1 <- res_count %>% select(Entity, Code, Year, researchers = 4)
df2 <- gdp       %>% select(Entity, Code, Year, gdp_per_capita = 4)
df3 <- gini      %>% select(Entity, Code, Year, gini_index = 4)
df4 <- edu_total %>% select(Entity, Code, Year, gov_edu_total = 4)
df5 <- rd_spend  %>% select(Entity, Code, Year, rd_share_gdp = 4)
df7 <- pop_edu   %>% select(Entity, Code, Year, pop_basic_edu = 4)
df6_all <- edu_tert %>% rename(exp_tert=4, exp_u_sec=5, exp_l_sec=6, exp_primary=7, exp_pre_pri=8)
# 2. Διαδοχική ένωση με τη merge()
# Χρησιμοποιούμε all = TRUE για να γίνει "Full Outer Join" (να μη χαθεί καμία γραμμή)
final_df <- merge(df1, df2, by = c("Entity", "Code", "Year"), all = TRUE)
final_df <- merge(final_df, df3, by = c("Entity", "Code", "Year"), all = TRUE)
final_df <- merge(final_df, df4, by = c("Entity", "Code", "Year"), all = TRUE)
final_df <- merge(final_df, df5, by = c("Entity", "Code", "Year"), all = TRUE)
final_df <- merge(final_df, df6_all, by = c("Entity", "Code", "Year"), all = TRUE)
final_df <- merge(final_df, df7, by = c("Entity", "Code", "Year"), all = TRUE)
# Ταξινόμηση για να είναι ευανάγνωστο
final_df <- final_df[order(final_df$Entity, final_df$Year), ]
# Έλεγχος
head(final_df)
View(final_df)
df_clean <- na.omit(final_df)
View(df_clean)
head(df_clean)
if(!require(caret)){
install.packages("caret")
library(caret)
}
if(!require(rpart)){
install.packages("rpart")
library(rpart)
}
if(!require(randomForest)){
install.packages("randomForest")
library(randomForest)
}
# 1. Διαχωρισμός σε Train και Test set (80/20)
set.seed(42)
index <- createDataPartition(df_clean$researchers, p = 0.8, list = FALSE)
train_set <- df_clean[index, ]
test_set  <- df_clean[-index, ]
# 2. Ορισμός Cross-Validation (10-fold)
# Αυτό θα δοκιμάσει διαφορετικές παραμέτρους για να βρει το καλύτερο μοντέλο
ctrl <- trainControl(method = "cv", number = 10)
# --- ΜΟΝΤΕΛΟ Α: Decision Tree ---
# Χρησιμοποιούμε τη μέθοδο 'rpart'
tree_fit <- train(researchers ~ . - Entity - Code - Year,
data = train_set,
method = "rpart",
trControl = ctrl,
tuneLength = 20)
# --- ΜΟΝΤΕΛΟ Β: Random Forest ---
# Χρησιμοποιούμε τη μέθοδο 'rf'
rf_fit <- train(researchers ~ . - Entity - Code - Year,
data = train_set,
method = "rf",
trControl = ctrl,
importance = TRUE,
ntree = 100) # Αριθμός δέντρων
# 3. Σύγκριση των δύο μοντέλων
results <- resamples(list(DecisionTree = tree_fit, RandomForest = rf_fit))
summary(results)
# Εγκατάσταση αν δεν το έχεις: install.packages("rpart.plot")
if(!require(rpart.plot)){
install.packages("rpart.plot")
library(rpart.plot)
}
# Σχεδίαση του δέντρου
rpart.plot(tree_fit$finalModel,
main = "Decision Tree για τον Αριθμό Ερευνητών",
under = TRUE,
faclen = 0,
type = 5)
