# Φόρτωση του knitr
if (!require("knitr")) install.packages("knitr")

# Λίστα με όλα τα qmd αρχεία στον τρέχοντα φάκελο
files <- list.files(pattern = "\\.qmd$", full.names = TRUE)

for (f in files) {
  # Η συνάρτηση αυτή κάνει τη "μαγεία"
  knitr::convert_chunk_header(f, output = f)
  message("Ολοκληρώθηκε η μετατροπή για το: ", f)
}